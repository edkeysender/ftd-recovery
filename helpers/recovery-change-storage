#!/usr/bin/env bash
# Switch the backup storage drive without reinstalling.
# Usage: sudo recovery-change-storage
#
# Keeps the old drive mounted throughout so images can be copied without
# a remount step. Only the bind (/srv/clonezilla-images) is torn down
# while the switch happens; the old underlying device stays accessible.

set -euo pipefail

LIB_DIR="/usr/local/lib/ftd-recovery"
# shellcheck source=/usr/local/lib/ftd-recovery/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=/usr/local/lib/ftd-recovery/disc-mapping.sh
source "$LIB_DIR/disc-mapping.sh"

require_root

echo
echo "${BOLD}${CYAN}FTD Recovery — change backup storage${RESET}"
echo

# ── Show current storage ──────────────────────────────────────────────────────
bind_src=$(awk '$2 == "/srv/clonezilla-images" && $1 !~ /^#/ {print $1; exit}' /etc/fstab || true)
underlying=""
if [[ -n "$bind_src" ]]; then
    underlying=$(dirname "$bind_src")
fi

echo "${BOLD}Current backup storage:${RESET}"
if mountpoint -q "$STORAGE_BIND" 2>/dev/null; then
    st=$(df -h "$STORAGE_BIND" | awk 'NR==2 {printf "%s used of %s", $3, $2}')
    echo "  path : $STORAGE_BIND"
    echo "  usage: $st"
    [[ -n "$underlying" ]] && echo "  mount: $underlying"
else
    echo "  ${YELLOW}not currently mounted${RESET}"
    [[ -n "$underlying" ]] && echo "  configured mount: $underlying"
fi
echo

# ── Pick new storage BEFORE touching anything ─────────────────────────────────
pick_storage

echo
echo "${BOLD}Ready to switch:${RESET}"
echo "  from : ${underlying:-(none)}"
echo "  to   : $PICK_DEV"
echo
warn "The bind mount will be briefly interrupted. The old drive stays mounted for image copying."
echo
if ! confirm "Proceed?" "n"; then
    echo "Aborted."; exit 0
fi

# ── Step 1: release the bind only ────────────────────────────────────────────
log "releasing bind mount"
systemctl stop recovery-interface nfs-server 2>/dev/null || true
exportfs -ua 2>/dev/null || true

if mountpoint -q "$STORAGE_BIND" 2>/dev/null; then
    umount "$STORAGE_BIND" 2>/dev/null || umount -l "$STORAGE_BIND"
    ok "unmounted $STORAGE_BIND"
fi

# Remove only the bind fstab entry — leave the underlying device entry in place.
sed -i "\|[[:space:]]${STORAGE_BIND}[[:space:]]|d" /etc/fstab
systemctl daemon-reload || true
ok "bind fstab entry removed"

# ── Step 2: mount new device at a temp path ───────────────────────────────────
log "mounting new device"
new_uuid=$(blkid -s UUID -o value "$PICK_DEV" 2>/dev/null || true)
new_fstype=$(blkid -s TYPE -o value "$PICK_DEV" 2>/dev/null || true)
[[ -z "$new_uuid" ]]   && die "$PICK_DEV has no filesystem"
[[ -z "$new_fstype" ]] && die "$PICK_DEV has no recognised filesystem"

new_mnt=$(mktemp -d /mnt/ftd-new-XXXXXX)
if ! mount -t "$new_fstype" "$PICK_DEV" "$new_mnt" 2>/dev/null; then
    if confirm "Mount failed — run fsck to repair $PICK_DEV?" "y"; then
        fsck -y "$PICK_DEV" || true
        mount -t "$new_fstype" "$PICK_DEV" "$new_mnt" || die "mount failed even after fsck"
        ok "filesystem repaired and mounted"
    else
        rmdir "$new_mnt" 2>/dev/null || true
        die "could not mount $PICK_DEV"
    fi
fi
ok "new device mounted at $new_mnt"

# ── Step 3: set up bind from new device ───────────────────────────────────────
log "setting up bind mount"
mkdir -p "$new_mnt/clonezilla-images"
chmod 1777 "$new_mnt/clonezilla-images"
echo "$new_mnt/clonezilla-images  $STORAGE_BIND  none  bind,nofail  0  0" >> /etc/fstab
systemctl daemon-reload || true
mount "$STORAGE_BIND" || die "bind-mount failed"
touch "$STORAGE_BIND/.ftd-writetest" || die "$STORAGE_BIND is not writable"
rm -f "$STORAGE_BIND/.ftd-writetest"
ok "$STORAGE_BIND is mounted and writable"

# ── Step 4: restart services ───────────────────────────────────────────────────
systemctl start nfs-server 2>/dev/null || true
exportfs -ra 2>/dev/null || true
systemctl restart recovery-interface
ok "recovery-interface restarted"

echo
echo "${BOLD}${GREEN}New storage active.${RESET}"

# ── Step 5: copy from old drive (still mounted — no remount needed) ───────────
_copy_old_backups() {
    local src_images=$1
    [[ ! -d "$src_images" ]] && return

    local -a images=()
    mapfile -t images < <(find "$src_images" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | sort)

    if [[ ${#images[@]} -eq 0 ]]; then
        log "no backup images found on old drive"
        return
    fi

    echo
    echo "${BOLD}Backup images on old drive:${RESET}"
    local i sz
    for i in "${!images[@]}"; do
        sz=$(du -sh "$src_images/${images[$i]}" 2>/dev/null | cut -f1 || echo "?")
        printf "  %s%d)%s %-40s  %s\n" "$BOLD" "$((i+1))" "$RESET" "${images[$i]}" "$sz"
    done
    printf "  %sa)%s Copy all\n" "$BOLD" "$RESET"
    echo

    local reply
    read -r -p "${BOLD}Copy which images to new drive? (number, 'a' for all, Enter to skip):${RESET} " reply </dev/tty

    [[ -z "$reply" ]] && { log "skipping copy"; return; }

    local -a to_copy=()
    if [[ "$reply" =~ ^[Aa]$ ]]; then
        to_copy=("${images[@]}")
    elif [[ "$reply" =~ ^[0-9]+$ ]] && (( reply >= 1 && reply <= ${#images[@]} )); then
        to_copy=("${images[$((reply-1))]}")
    else
        warn "invalid selection; skipping copy"
        return
    fi

    log "copying ${#to_copy[@]} image(s) to $STORAGE_BIND ..."
    local img
    for img in "${to_copy[@]}"; do
        log "copying $img ..."
        rsync -a --info=progress2 "$src_images/$img" "$STORAGE_BIND/"
        ok "copied $img"
    done
}

if [[ -n "$bind_src" && -d "$bind_src" ]]; then
    echo
    echo "${BOLD}Old drive is still mounted at $underlying.${RESET}"
    echo "You can copy existing backup images to the new drive now."
    if confirm "Copy existing backups from old drive to new one?" "y"; then
        _copy_old_backups "$bind_src"
    else
        log "skipping copy — old images remain at $underlying"
    fi
fi

# ── Step 6: clean up old mount and standardise new mount path ─────────────────
log "finalising storage layout"

# Unmount old underlying (if it's not a system path and still mounted).
case "${underlying:-}" in
    /|/boot|/boot/*|/usr|/usr/*|/var|/var/*|"") : ;;
    *)
        if mountpoint -q "$underlying" 2>/dev/null; then
            umount "$underlying" 2>/dev/null || umount -l "$underlying"
            ok "unmounted old drive ($underlying)"
        fi
        sed -i "\|[[:space:]]${underlying}[[:space:]]|d" /etc/fstab
        ;;
esac

# Move new device from temp path to the standard /mnt/ftd-backup.
std_mnt="/mnt/ftd-backup"
if [[ "$new_mnt" != "$std_mnt" ]]; then
    # Remove temp bind+underlying fstab entries and replace with standard paths.
    sed -i "\|[[:space:]]${STORAGE_BIND}[[:space:]]|d" /etc/fstab
    sed -i "\|[[:space:]]${new_mnt}[[:space:]]|d" /etc/fstab

    umount "$STORAGE_BIND" 2>/dev/null || true
    umount "$new_mnt"      2>/dev/null || true
    rmdir  "$new_mnt"      2>/dev/null || true

    mkdir -p "$std_mnt"
    echo "UUID=$new_uuid  $std_mnt  $new_fstype  defaults,noatime,nofail  0  2" >> /etc/fstab
    echo "$std_mnt/clonezilla-images  $STORAGE_BIND  none  bind,nofail,x-systemd.requires-mounts-for=$std_mnt  0  0" >> /etc/fstab
    systemctl daemon-reload || true
    mount "$std_mnt"      || die "final mount of $std_mnt failed"
    mount "$STORAGE_BIND" || die "final bind-mount failed"
    chmod 1777 "$STORAGE_BIND"
    systemctl restart recovery-interface
fi

ok "storage layout finalised at $std_mnt"
echo
echo "${BOLD}${GREEN}Done.${RESET} Backup storage: $std_mnt ($PICK_DEV)"

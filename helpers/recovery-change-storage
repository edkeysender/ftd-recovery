#!/usr/bin/env bash
# Switch the backup storage drive without reinstalling.
# Usage: sudo recovery-change-storage
#
# Tears down the current storage mount, runs the interactive storage
# picker (same as the installer), updates fstab, and restarts the app.
# Optionally copies existing backup images from the old drive to the new one.

set -euo pipefail

LIB_DIR="/usr/local/lib/ftd-recovery"
# shellcheck source=/usr/local/lib/ftd-recovery/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=/usr/local/lib/ftd-recovery/disc-mapping.sh
source "$LIB_DIR/disc-mapping.sh"

require_root

echo
echo "${BOLD}${CYAN}FTD Recovery — change backup storage${RESET}"
echo

# ── Show current storage ─────────────────────────────────────────────────────
bind_src=$(awk '$2 == "/srv/clonezilla-images" && $1 !~ /^#/ {print $1; exit}' /etc/fstab || true)
underlying=""
if [[ -n "$bind_src" ]]; then
    underlying=$(dirname "$bind_src")
fi

echo "${BOLD}Current backup storage:${RESET}"
if mountpoint -q "$STORAGE_BIND" 2>/dev/null; then
    st=$(df -h "$STORAGE_BIND" | awk 'NR==2 {printf "%s used of %s", $3, $2}')
    echo "  path : $STORAGE_BIND"
    echo "  usage: $st"
    [[ -n "$underlying" ]] && echo "  mount: $underlying"
else
    echo "  ${YELLOW}not currently mounted${RESET}"
    [[ -n "$underlying" ]] && echo "  configured mount: $underlying"
fi
echo

# ── Pick new storage BEFORE touching anything ────────────────────────────────
pick_storage

echo
echo "${BOLD}Ready to switch:${RESET}"
echo "  from : ${underlying:-(none)}"
echo "  to   : $PICK_DEV"
echo
warn "The current drive will be unmounted. Existing backup images will not be deleted."
echo
if ! confirm "Proceed?" "n"; then
    echo "Aborted."; exit 0
fi

# ── Capture old device before teardown ──────────────────────────────────────
old_bind_src="$bind_src"
old_device=""
if [[ -n "$underlying" ]] && mountpoint -q "$underlying" 2>/dev/null; then
    old_device=$(findmnt -no SOURCE "$underlying" 2>/dev/null || true)
fi

# ── Step 1: tear down current storage ───────────────────────────────────────
log "removing current storage configuration"

# Stop services that hold the mount open.
systemctl stop recovery-interface nfs-server 2>/dev/null || true
exportfs -ua 2>/dev/null || true

# Unmount in order: bind first, then underlying device.
# Fall back to lazy unmount (-l) if something still holds it briefly.
if mountpoint -q "$STORAGE_BIND" 2>/dev/null; then
    umount "$STORAGE_BIND" 2>/dev/null || umount -l "$STORAGE_BIND"
    ok "unmounted $STORAGE_BIND"
fi
case "${underlying:-}" in
    /|/boot|/boot/*|/usr|/usr/*|/var|/var/*)
        warn "current storage is on a system path ($underlying) — skipping unmount" ;;
    "")
        : ;;
    *)
        if mountpoint -q "$underlying" 2>/dev/null; then
            umount "$underlying" 2>/dev/null || umount -l "$underlying"
            ok "unmounted $underlying"
        fi ;;
esac

# Remove old fstab entries for the bind and underlying mount.
sed -i "\|[[:space:]]${STORAGE_BIND}[[:space:]]|d" /etc/fstab
case "${underlying:-}" in
    /|/boot|/boot/*|/usr|/usr/*|/var|/var/*|"") : ;;
    *) sed -i "\|[[:space:]]${underlying}[[:space:]]|d" /etc/fstab ;;
esac
systemctl daemon-reload || true
ok "old fstab entries removed"

# ── Step 2: apply selected storage ───────────────────────────────────────────
case "$PICK_MODE" in
    adopt)  _mode2_adopt_partition "$PICK_DEV" ;;
    format) _mode3_format_disk     "$PICK_DEV" ;;
esac
_setup_bind_mount

# ── Step 3: restart services ─────────────────────────────────────────────────
systemctl start nfs-server 2>/dev/null || true
exportfs -ra 2>/dev/null || true
systemctl restart recovery-interface
ok "recovery-interface restarted"

echo
echo "${BOLD}${GREEN}Storage changed.${RESET} New path: $STORAGE_UNDERLYING"
echo "Existing images on the old drive were not touched."

# ── Step 4: offer to copy backups from old storage ───────────────────────────
_copy_old_backups() {
    local src_images=$1  # directory containing the image folders to copy from

    if [[ ! -d "$src_images" ]]; then
        return
    fi

    local -a images=()
    mapfile -t images < <(find "$src_images" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | sort)

    if [[ ${#images[@]} -eq 0 ]]; then
        log "no backup images found on old drive"
        return
    fi

    echo
    echo "${BOLD}Backup images on old drive:${RESET}"
    local i sz
    for i in "${!images[@]}"; do
        sz=$(du -sh "$src_images/${images[$i]}" 2>/dev/null | cut -f1 || echo "?")
        printf "  %s%d)%s %-40s  %s\n" "$BOLD" "$((i+1))" "$RESET" "${images[$i]}" "$sz"
    done
    printf "  %sa)%s Copy all\n" "$BOLD" "$RESET"
    echo

    local reply
    read -r -p "${BOLD}Copy which images to new drive? (number, 'a' for all, Enter to skip):${RESET} " reply </dev/tty

    if [[ -z "$reply" ]]; then
        log "skipping copy"
        return
    fi

    local -a to_copy=()
    if [[ "$reply" =~ ^[Aa]$ ]]; then
        to_copy=("${images[@]}")
    elif [[ "$reply" =~ ^[0-9]+$ ]] && (( reply >= 1 && reply <= ${#images[@]} )); then
        to_copy=("${images[$((reply-1))]}")
    else
        warn "invalid selection; skipping copy"
        return
    fi

    local dst="/srv/clonezilla-images"
    log "copying ${#to_copy[@]} image(s) to $dst ..."
    local img
    for img in "${to_copy[@]}"; do
        log "copying $img ..."
        rsync -a --info=progress2 "$src_images/$img" "$dst/"
        ok "copied $img"
    done
}

if [[ -n "$old_bind_src" ]]; then
    echo
    if [[ -n "$old_device" ]]; then
        # Old storage was a mounted block device — remount temporarily.
        tmp_mnt=$(mktemp -d /mnt/ftd-old-XXXXXX)
        if mount "$old_device" "$tmp_mnt" 2>/dev/null; then
            old_images_dir="$tmp_mnt/clonezilla-images"
            if confirm "Copy existing backups from old drive to new one?" "n"; then
                _copy_old_backups "$old_images_dir"
            fi
            umount "$tmp_mnt"
        else
            warn "could not remount old drive ($old_device); copy it manually if needed"
        fi
        rmdir "$tmp_mnt" 2>/dev/null || true
    else
        # Old storage was a local folder — still accessible.
        if confirm "Copy existing backups from old location to new one?" "n"; then
            _copy_old_backups "$old_bind_src"
        fi
    fi
fi
